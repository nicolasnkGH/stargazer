# StarGazer — Environment Variables
# Copy this to .env and fill in your values

# --- Observer Location ---
OBSERVER_LAT=40.126
OBSERVER_LON=-83.037
OBSERVER_ELEVATION_M=240
OBSERVER_TIMEZONE=America/New_York

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# --- NASA APOD (optional, free at https://api.nasa.gov) ---
# Without this, uses DEMO_KEY (limited to 30 req/hour)
NASA_APOD_KEY=DEMO_KEY

# --- API internal URL (used by n8n workflows) ---
# If running on same Docker network as n8n:
STARGAZER_API_URL=http://stargazer-api:8181
# If running on a separate LXC, use its IP:
# STARGAZER_API_URL=http://192.168.1.XXX:8181
